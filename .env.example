# ============================================
# KIRA — Environment Configuration
# ============================================
# Copy this file to .env and fill in values
# ============================================

# DEPLOYMENT MODE
# Options: cloud | raspberry_pi
DEPLOYMENT=cloud

# ============================================
# AI APIs — At least ONE required
# ============================================
GEMINI_API_KEY=your_gemini_key_here
OPENROUTER_API_KEY=your_openrouter_key_here
OPENAI_API_KEY=your_openai_key_here

# AI Model preferences
GEMINI_MODEL=gemini-1.5-flash
OPENROUTER_MODEL=mistralai/mistral-7b-instruct
OPENAI_MODEL=gpt-4o-mini

# ============================================
# OFFLINE LLM (Raspberry Pi / Local)
# ============================================
OFFLINE_LLM_URL=http://localhost:11434
OFFLINE_LLM_MODEL=llama3

# ============================================
# VOICE — STT (Speech to Text)
# ============================================
# Groq — Fast & Free STT
GROQ_API_KEY=your_groq_key_here

# ============================================
# VOICE — TTS (Text to Speech)
# ============================================
# Option 1: Google TTS (Free, Indian voice)
TTS_GOOGLE_LANGUAGE=hi
TTS_GOOGLE_TLD=co.in

# Option 2: ElevenLabs (Ultra human voice)
ELEVENLABS_API_KEY=your_elevenlabs_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here

# Option 3: Custom (Fill via Kira command)
CUSTOM_TTS_API_KEY=
CUSTOM_TTS_URL=
CUSTOM_TTS_MODEL=

# Active TTS — Options: google | elevenlabs | custom
TTS_PROVIDER=google

# ============================================
# WAKE WORD
# ============================================
PORCUPINE_ACCESS_KEY=your_porcupine_key_here
WAKE_WORD=kira
WAKE_WORD_SENSITIVITY=0.7
WAKE_WORD_TIMEOUT=120

# ============================================
# SECURITY
# ============================================
# Secret key for JWT tokens
SECRET_KEY=change_this_to_random_long_string

# PIN — Will be set via app, this is default
DEFAULT_PIN=1234
PIN_RESET_HOURS=24
MAX_PIN_ATTEMPTS=5
LOCKOUT_ATTEMPTS=10

# Security code for code analysis/updates
SECURITY_CODE=your_security_code_here

# ============================================
# GOOGLE SEARCH
# ============================================
GOOGLE_SEARCH_API_KEY=your_google_search_key
GOOGLE_SEARCH_CX=your_custom_search_engine_id

# ============================================
# DATABASE
# ============================================
DATABASE_URL=sqlite+aiosqlite:///./kira_memory.db

# ============================================
# REDIS (Optional — for caching)
# ============================================
REDIS_URL=redis://localhost:6379

# ============================================
# APP CONFIG
# ============================================
APP_HOST=0.0.0.0
APP_PORT=8000
DEBUG=false

# Kira personality name
KIRA_NAME=Kira

# Default language
DEFAULT_LANGUAGE=hinglish

# Response style — short | medium | detailed
RESPONSE_STYLE=short
